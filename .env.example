# ===== 智谱 GLM coding-plan 网关 =====
# 复用环境已有变量；若缺失请在此填入真实值后复制为 .env
# base_url：coding-plan 网关地址（OpenAI 兼容）
ZCODE_BASE_URL=
ZAI_BUSINESS_BASE_URL=

# API Key（任一即可，按你的网关约定）
ZHIPU_API_KEY=
ZCODE_API_KEY=

# 模型
GLM_MODEL=GLM-5.2
ENABLE_THINKING=false  # 全局默认(被自适应覆盖); ADAPTIVE_THINKING 默认开启按难度自动切换
EMBEDDING_MODEL=embedding-3
RERANK_MODEL=reranker        # 若无 rerank API，将回退 MMR 本地重排

# RAG 参数
CHUNK_SIZE=1024
CHUNK_OVERLAP=128
RETRIEVE_TOPK=20
RERANK_TOPN=5

# 知识库目录（支持外部仓库）
KNOWLEDGE_DIR=data/knowledge
